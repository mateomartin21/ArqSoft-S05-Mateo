@{
    ViewData["Title"] = "Inicio";
}

<div class="hero">
    <h1>Sistema de Citas Médicas</h1>
    <p>Gestiona pacientes, médicos y agenda de manera sencilla y rápida.</p>

    <div class="hero-cards">
        <a class="hero-card" asp-controller="Paciente" asp-action="Index">
            <div class="icon">🧑‍⚕️</div>
            <div class="label">Pacientes</div>
        </a>
        <a class="hero-card" asp-controller="Medico" asp-action="Index">
            <div class="icon">👨‍⚕️</div>
            <div class="label">Médicos</div>
        </a>
        <a class="hero-card" asp-controller="Cita" asp-action="Index">
            <div class="icon">📅</div>
            <div class="label">Agenda</div>
        </a>
    </div>
</div>

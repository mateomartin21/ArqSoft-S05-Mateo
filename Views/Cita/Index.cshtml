@model List<CitasApp.Domain.Models.Cita>
@using CitasApp.Domain.Models

@{
    var pacientes = ViewBag.Pacientes as List<Paciente>;
    var medicos = ViewBag.Medicos as List<Medico>;
}

<h1>Agenda de citas</h1>

<a asp-action="Crear">+ Nueva cita</a>
<br />
<br />

<table border="1" cellpadding="8">
    <tr>
        <th>Fecha</th>
        <th>Hora</th>
        <th>Paciente</th>
        <th>MÈdico</th>
        <th>Motivo</th>
        <th>Estado</th>
        <th>Acciones</th>
    </tr>
    @foreach (var c in Model)
    {
        var paciente = pacientes?.FirstOrDefault(p => p.Id == c.PacienteId);
        var medico = medicos?.FirstOrDefault(m => m.Id == c.MedicoId);
        <tr>
            <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
            <td>@c.Hora.ToString("HH:mm")</td>
            <td>@(paciente != null ? $"{paciente.Nombre} {paciente.Apellido}" : "ó")</td>
            <td>@(medico != null ? $"{medico.Nombre} {medico.Apellido}" : "ó")</td>
            <td>@c.Motivo</td>
            <td>@c.Estado</td>
            <td>
                <form asp-action="Eliminar" method="post"
                      onsubmit="return confirm('øEliminar esta cita?')">
                    <input type="hidden" name="id" value="@c.Id" />
                    <button type="submit">Eliminar</button>
                </form>
            </td>
        </tr>
    }
</table>



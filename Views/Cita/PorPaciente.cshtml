@model List<CitasApp.Domain.Models.Cita>
@using CitasApp.Domain.Models

@{
    var pacientes = ViewBag.Pacientes as List<Paciente>;
    var medicos = ViewBag.Medicos as List<Medico>;
    var primero = Model.FirstOrDefault();
    var paciente = pacientes?.FirstOrDefault(p => p.Id == primero?.PacienteId);
}

<h1>Citas de @(paciente != null ? $"{paciente.Nombre} {paciente.Apellido}" : "paciente")</h1>
<table border="1" cellpadding="8">
    <tr>
        <th>Fecha</th>
        <th>Hora</th>
        <th>Médico</th>
        <th>Motivo</th>
        <th>Estado</th>
    </tr>
    @foreach (var c in Model)
    {
        var medico = medicos?.FirstOrDefault(m => m.Id == c.MedicoId);
        <tr>
            <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
            <td>@c.Hora.ToString("HH:mm")</td>
            <td>@(medico != null ? $"{medico.Nombre} {medico.Apellido}" : "—")</td>
            <td>@c.Motivo</td>
            <td>@c.Estado</td>
        </tr>
    }
</table>
<br />
<a asp-controller="Cita" asp-action="Index">? Ver todas las citas</a>



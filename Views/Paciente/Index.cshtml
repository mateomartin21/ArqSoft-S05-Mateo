@model List<CitasApp.Models.Paciente>
<h1>Pacientes registrados</h1>
<table border="1" cellpadding="8">
    <tr>
        <th>Nombre</th>
        <th>Email</th>
        <th>Teléfono</th>
        <th></th>
    </tr>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Nombre @p.Apellido</td>
            <td>@p.Email</td>
            <td>@p.Telefono</td>
            <td><a asp-action="Detalle" asp-route-id="@p.Id">Ver detalle</a></td>
        </tr>
    }
</table>
